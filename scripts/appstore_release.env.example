# Copy this file to .env.appstoreconnect and fill in the real values.
# Never commit .env.appstoreconnect or AuthKey_*.p8 files.

export ASC_KEY_ID="REPLACE_WITH_KEY_ID"
export ASC_KEY_TYPE="individual"
# Team keys require ASC_ISSUER_ID. Individual keys intentionally leave it blank.
# export ASC_ISSUER_ID="REPLACE_WITH_ISSUER_ID"
export ASC_PRIVATE_KEY_PATH="$HOME/.appstoreconnect/ApiKey_REPLACE_WITH_KEY_ID.p8"

# 1S0 Inspector Trainer defaults.
export ASC_APP_ID="6758813561"
export ASC_BUNDLE_ID="com.abdoulbah.1s0-inspector-trainer"
export ASC_TEAM_ID="MM76BGJBJR"
